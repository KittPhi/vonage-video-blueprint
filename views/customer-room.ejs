<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link
      rel="stylesheet"
      href="<%= appURI.replace(/\/+$/, '') %>/css/style.css"
    />
    <%- include('common/styles'); -%>
    <link
      rel="stylesheet"
      href="<%= appURI.replace(/\/+$/, '') %>/css/customer-room.css"
    />

    <script src="https://video.standard.vonage.com/v2/js/opentok.min.js"></script>
    <script type="text/javascript">
      var apiKey = "<%= vonageData.apiKey %>";
      var sessionId = "<%= vonageData.sessionId %>";
      var token = "<%= vonageData.token %>";
      var userName = "<%= vonageData.userName %>";
      var roomRole = "<%= roomRole %>";
      var publishAudio = <%= publishAudio %>;
    </script>
  </head>
  <body>
    <%- include('common/header'); -%>

    <div class="container customer-room">
      <div class="container">
        <div class="row">
          <div class="col-md mx-auto">
            <div class="text-center">Agent</div>
            <div class="stream-container mx-auto">
              <div id="subscribers"></div>
            </div>
          </div>
          <div class="col-md mx-auto">
            <div class="text-center">Customer</div>
            <div class="stream-container mx-auto">
              <div id="publisher"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="vonage-logo">
        <img
          src="<%= appURI.replace(/\/+$/, '') %>/img/vonage-white.png"
          alt=""
          srcset=""
        />
      </div>
    </div>
    <script
      type="module"
      src="<%= appURI.replace(/\/+$/, '') %>/js/vonage-room/room.js"
    ></script>
  </body>
</html>
